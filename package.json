{
  "name": "webapp",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:cache": "npx synpress ./testing/setup",
    "test:docs": "npm run test:cache && npx playwright test testing/tests/metamask-docs.test.ts",
    "test:signin-conditions": "npm run test:cache && npx playwright test testing/tests/metamask-signin-conditions.test.ts",
    "test:auth-flow": "npm run test:cache && npx playwright test testing/tests/metamask-auth-flow.test.ts",
    "test:network-warning": "npm run test:cache && npx playwright test testing/tests/network-warning-banner.test.ts",
    "test:user-edit-modal": "npm run test:cache && npx playwright test testing/tests/user-edit-modal.test.ts",
    "test:browser": "npx playwright test testing/tests/browser-compatibility.test.ts",
    "test:all-metamask": "npm run test:cache && npx playwright test testing/tests/metamask-*.test.ts && npx playwright test testing/tests/network-warning-banner.test.ts && npx playwright test testing/tests/user-edit-modal.test.ts",
    "test:all": "npm run test:cache && npx playwright test testing/tests/metamask-*.test.ts && npx playwright test testing/tests/browser-compatibility.test.ts",
    "test:everything": "npm run test:unit && npm run test:all"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.11",
    "@radix-ui/react-scroll-area": "^1.2.6",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@react-router/fs-routes": "^7.2.0",
    "@react-router/node": "^7.2.0",
    "@react-router/serve": "^7.2.0",
    "@ricky0123/vad-react": "^0.0.30",
    "@tanstack/react-query": "^5.84.0",
    "add": "^2.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esp-web-tools": "^10.1.0",
    "ethers": "^6.13.5",
    "isbot": "^5",
    "moment": "^2.30.1",
    "mqtt": "^5.10.3",
    "npm": "^11.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-infinite-scroll-hook": "^6.0.1",
    "react-markdown": "^10.0.1",
    "react-router": "^7.2.0",
    "react-use-audio-player": "^4.0.2",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.1",
    "tailwind-scrollbar": "^4.0.1",
    "tailwind-variants": "^0.3.1",
    "usehooks-ts": "^3.1.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.48.2",
    "@react-router/dev": "^7.2.0",
    "@synthetixio/synpress": "^4.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query-devtools": "^5.84.0",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "msw": "^2.10.5",
    "prettier": "^3.5.1",
    "react-router-devtools": "^1.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-svgr": "^4.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@ricky0123/vad-react": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
